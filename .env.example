# Token do bot do Telegram (pegue com o @BotFather)
BOT_TOKEN=

# Connection string do MongoDB.
# No Railway, use a variável MONGO_URL do serviço Mongo (Reference Variable).
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=todos

# Lembrete diário (hora local do fuso abaixo)
TIMEZONE=America/Sao_Paulo
REMINDER_HOUR=8
REMINDER_MINUTE=0
